{
  "name": "Retro Pop Art",
  "description": "70s retro pop art color palette for PPT slides",
  "background": "#F5F0E6",
  "colors": {
    "salmon-pink": {
      "hex": "#FF6B6B",
      "rgb": [255, 107, 107],
      "usage": "Primary accents, key headlines, important data"
    },
    "sky-blue": {
      "hex": "#4ECDC4",
      "rgb": [78, 205, 196],
      "usage": "Secondary information, chart elements"
    },
    "mustard-yellow": {
      "hex": "#FFD93D",
      "rgb": [255, 217, 61],
      "usage": "Highlights, callout boxes, emphasis"
    },
    "mint-green": {
      "hex": "#6BCB77",
      "rgb": [107, 203, 119],
      "usage": "Positive data, growth indicators"
    }
  },
  "contrast": {
    "pure-black": {
      "hex": "#000000",
      "usage": "Text, outlines, divider lines"
    },
    "pure-white": {
      "hex": "#FFFFFF",
      "usage": "Reverse text blocks, contrast backgrounds"
    }
  },
  "usage-guidelines": {
    "do": [
      "Use flat colors without gradients",
      "Apply thick black outlines (2-4px)",
      "Maintain high contrast between elements",
      "Use cream background consistently"
    ],
    "dont": [
      "Avoid gradients and shadows",
      "Don't use thin lines (< 2px)",
      "Avoid pastel or neon variations",
      "Don't mix with realistic imagery"
    ]
  }
}
